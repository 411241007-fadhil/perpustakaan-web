<%- include('partials/header') %>
<div class="card-header-theme">Edit Rekord Transaksi Peminjaman</div>
<div class="content-box">
    <form action="/modules/peminjaman/edit/<%= data.id_pinjam %>" method="POST">
        <div class="form-group">
            <label>Buku Terpinjam</label>
            <select name="id_buku" class="form-control" required>
                <% buku.forEach(item => { %>
                    <option value="<%= item.id_buku %>" <%= data.id_buku === item.id_buku ? 'selected' : '' %>><%= item.judul %></option>
                <% }) %>
            </select>
        </div>
        <div class="form-group">
            <label>Anggota Peminjam</label>
            <select name="id_peminjam" class="form-control" required>
                <% peminjam.forEach(item => { %>
                    <option value="<%= item.id_peminjam %>" <%= data.id_peminjam === item.id_peminjam ? 'selected' : '' %>><%= item.nama %></option>
                <% }) %>
            </select>
        </div>
        <div class="form-group">
            <label>Tanggal Pinjam</label>
            <input type="date" name="tanggal_pinjam" value="<%= data.tanggal_pinjam %>" class="form-control" required>
        </div>
        <div class="form-group">
            <label>Tanggal Kembali</label>
            <input type="date" name="tanggal_kembali" value="<%= data.tanggal_kembali %>" class="form-control" required>
        </div>
        <div class="form-group">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="Dipinjam" <%= data.status === 'Dipinjam' ? 'selected' : '' %>>Dipinjam</option>
                <option value="Dikembalikan" <%= data.status === 'Dikembalikan' ? 'selected' : '' %>>Dikembalikan</option>
            </select>
        </div>
        <button type="submit" class="btn btn-warning">Perbarui Transaksi</button>
        <a href="/modules/peminjaman" class="btn btn-secondary">Batal</a>
    </form>
</div>
<%- include('partials/footer') %>